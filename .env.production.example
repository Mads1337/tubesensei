# TubeSensei Production Environment Variables
# Copy this file to .env and fill in all required values before deploying.
#
# Generate a secret key:   openssl rand -hex 32
# Generate a password:     openssl rand -base64 24


# ==============================================================================
# REQUIRED - Must Set Before Deploying
# ==============================================================================

# PostgreSQL connection string (asyncpg driver required)
# The postgres hostname matches the service name in docker-compose.prod.yml
DATABASE_URL=postgresql+asyncpg://tubesensei:CHANGE_ME@postgres:5432/tubesensei

# PostgreSQL password (must match the password in DATABASE_URL above)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis password (used by all services that connect to Redis)
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Secret key for JWT/session signing - generate with: openssl rand -hex 32
SECURITY_SECRET_KEY=GENERATE_WITH_openssl_rand_-hex_32


# ==============================================================================
# API Keys (at least one LLM key is required for AI features)
# ==============================================================================

YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# LLM providers - provide at least one
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key
GEMINI_API_KEY=your_gemini_api_key

# Optional LLM providers
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
QWEN_API_KEY=your_qwen_api_key
SERPER_API_KEY=your_serper_api_key_for_web_search


# ==============================================================================
# Security
# ==============================================================================

# JSON list of allowed CORS origins
SECURITY_ALLOWED_ORIGINS=["https://yourdomain.com"]

# JSON list of allowed hosts for TrustedHost middleware
SECURITY_ALLOWED_HOSTS=["yourdomain.com"]


# ==============================================================================
# Application Settings
# ==============================================================================

ENVIRONMENT=production
DEBUG=False
RELOAD=False

# Number of gunicorn workers (default: 4)
WORKERS=4

# Number of Celery worker processes per worker container (default: 4)
WORKER_CONCURRENCY=4


# ==============================================================================
# Database Pool Settings
# ==============================================================================

DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=False


# ==============================================================================
# Redis Settings
# ==============================================================================

# REDIS_URL is constructed from REDIS_PASSWORD in docker-compose.prod.yml.
# Set this only if you are connecting to an external Redis instance.
# REDIS_URL=redis://:your_password@your_redis_host:6379/0

REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECTION_TIMEOUT=5


# ==============================================================================
# Celery Settings
# ==============================================================================

CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000


# ==============================================================================
# Flower Monitoring
# ==============================================================================

# Basic auth for the Flower task monitor UI (user:password)
FLOWER_BASIC_AUTH=admin:CHANGE_ME_FLOWER_PASSWORD


# ==============================================================================
# Logging
# ==============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/app/logs/tubesensei.log


# ==============================================================================
# YouTube API Settings
# ==============================================================================

YOUTUBE_QUOTA_PER_DAY=10000
YOUTUBE_MAX_RESULTS_PER_PAGE=50
YOUTUBE_REQUEST_TIMEOUT=30
YOUTUBE_CACHE_TTL=86400


# ==============================================================================
# Transcript Processing Settings
# ==============================================================================

TRANSCRIPT_TIMEOUT_SECONDS=300
TRANSCRIPT_MAX_RETRIES=3
TRANSCRIPT_CACHE_TTL_HOURS=168
MIN_TRANSCRIPT_WORD_COUNT=100
MAX_TRANSCRIPT_LENGTH=500000
TRANSCRIPT_BATCH_SIZE=10
TRANSCRIPT_QUALITY_THRESHOLD=0.6

# Optional: proxy for transcript requests (to avoid IP blocks)
# TRANSCRIPT_PROXY_ENABLED=False
# TRANSCRIPT_PROXY_TYPE=generic
# TRANSCRIPT_PROXY_HTTP_URL=http://user:pass@proxy:port
# TRANSCRIPT_PROXY_HTTPS_URL=https://user:pass@proxy:port
# TRANSCRIPT_WEBSHARE_USERNAME=
# TRANSCRIPT_WEBSHARE_PASSWORD=


# ==============================================================================
# LLM Settings
# ==============================================================================

LLM_CACHE_TTL=86400
LLM_MAX_RETRIES=3
LLM_DEFAULT_TEMPERATURE=0.7
LLM_COST_TRACKING_ENABLED=True


# ==============================================================================
# Topic Discovery Settings
# ==============================================================================

TOPIC_DEFAULT_VIDEO_LIMIT=3000
TOPIC_DEFAULT_CHANNEL_LIMIT=5
TOPIC_SEARCH_LIMIT=50
TOPIC_SIMILAR_DEPTH=2
TOPIC_FILTER_THRESHOLD=0.7
TOPIC_FILTER_BATCH_SIZE=10
TOPIC_FILTER_MODEL=gemini-2.5-flash-lite
TOPIC_RATE_LIMIT=0.5
TOPIC_MAX_CONCURRENT_AGENTS=3


# ==============================================================================
# Security Cookie Settings
# ==============================================================================

SECURITY_SESSION_COOKIE_SECURE=True
SECURITY_SESSION_COOKIE_HTTPONLY=True
SECURITY_SESSION_COOKIE_SAMESITE=lax
SECURITY_SESSION_EXPIRE_HOURS=24
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=10080
SECURITY_REFRESH_TOKEN_EXPIRE_MINUTES=43200


# ==============================================================================
# Feature Flags
# ==============================================================================

FEATURES_ENABLE_REGISTRATION=True
FEATURES_ENABLE_API_DOCS=True
FEATURES_ENABLE_METRICS=True
FEATURES_ENABLE_HEALTH_CHECKS=True


# ==============================================================================
# Performance Settings
# ==============================================================================

CACHE_DEFAULT_TTL=3600
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60
MAX_CONCURRENT_JOBS=10
MAX_VIDEOS_PER_BATCH=50
BATCH_SIZE=100
MAX_RETRIES=3
